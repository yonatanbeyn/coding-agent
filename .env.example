# ── LLM Provider ─────────────────────────────────────────────────────────────
# Provider: anthropic | openai | ollama
AGENT_PROVIDER=anthropic

# Model name (leave blank to use provider default)
# Anthropic:  claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
# OpenAI:     gpt-4o | gpt-4o-mini | o1
# Ollama:     llama3.2 | mistral | codestral
AGENT_MODEL=claude-sonnet-4-6

# API key (can also use provider-specific env vars below)
AGENT_API_KEY=

# Anthropic key (used if AGENT_API_KEY not set)
ANTHROPIC_API_KEY=
# OpenAI key (used if AGENT_API_KEY not set)
OPENAI_API_KEY=sk-...

# Custom base URL (for Ollama, OpenRouter, Groq, vLLM, LM Studio, etc.)
# Ollama:     http://localhost:11434/v1
# Groq:       https://api.groq.com/openai/v1
# OpenRouter: https://openrouter.ai/api/v1
AGENT_BASE_URL=

# ── Agent settings ────────────────────────────────────────────────────────────
# Working directory (defaults to current directory)
AGENT_WORKSPACE=

# Max tool-call iterations per request
AGENT_MAX_ITERATIONS=50

# Enable streaming output
AGENT_STREAM=true

# ── AWS credentials ───────────────────────────────────────────────────────────
# (or use: aws configure / ~/.aws/credentials)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
